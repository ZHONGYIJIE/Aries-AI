# Ignore all temp assets and tool copies
/temp
#语音模型
/app/src/main/assets
*.iml
.gradle
/local.properties
/.idea/
/.kotlin/
/.vscode/
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

build/
/app/build/
release/

# Local environment / secrets
.env
.env.*
!.env.example
.env.local
.env.*.local
.env.prod
*.bak*

# Signing keys and certificates
*.jks
*.keystore
*.p12
*.pfx
*.pem
release.keystore

# Build outputs that may contain metadata
*.apk
*.aab
*.aar

# Exclude sherpa model binaries (too large for GitHub)
app/src/main/assets/sherpa-models/*
!app/src/main/assets/sherpa-models/README.md

# 忽略所有日志文件
*.log
logs/
**/logs/
**/*.log

# Local-only temporary files
AGENTS.md
analytics.settings
key/key

# Lighthouse reports (local performance profiling artifacts)
Aries-site/lighthouse-*.report.html
Aries-site/lighthouse-*.report.json
