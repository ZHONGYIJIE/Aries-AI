<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.M3t.History.Item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/m3t_spacing_xxxs"
    android:layout_marginBottom="@dimen/m3t_spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/m3t_spacing_lg">

        <ImageView style="@style/Widget.M3t.History.ItemIcon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/m3t_spacing_lg"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.M3t.Title.Medium" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/m3t_spacing_xs"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.M3t.Body.Small" />

        </LinearLayout>

        <ImageView style="@style/Widget.M3t.History.ItemChevron" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>