<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="@dimen/m3t_dialog_padding">

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchPrerelease"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/m3t_updates_include_prerelease"
        android:textAppearance="@style/TextAppearance.M3t.Body.Medium"
        android:textColor="@color/m3t_on_surface" />

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/m3t_spacing_md"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/m3t_spacing_sm"
        android:textAppearance="@style/TextAppearance.M3t.Body.Small"
        android:textColor="@color/m3t_error"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerReleases"
        android:layout_width="match_parent"
        android:layout_height="@dimen/m3t_update_history_list_height"
        android:layout_marginTop="@dimen/m3t_spacing_md" />

</LinearLayout>
