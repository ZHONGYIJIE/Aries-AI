<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialogContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/cardAgreement"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/m3t_drawer_background"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/agreementHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/m3t_spacing_xxl"
            android:paddingTop="@dimen/m3t_spacing_md"
            android:paddingEnd="@dimen/m3t_spacing_xxl">

            <TextView
                android:id="@+id/tvAgreementTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/m3t_spacing_lg"
                android:gravity="center"
                android:text="@string/user_agreement_title"
                android:textAppearance="@style/TextAppearance.M3t.Title.Large" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/m3t_spacing_sm"
                android:gravity="center"
                android:text="@string/user_agreement_desc"
                android:textAppearance="@style/TextAppearance.M3t.Body.Medium"
                android:textColor="@color/blue_glass_text_dim" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollAgreement"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls"
            android:paddingStart="@dimen/m3t_spacing_xxl"
            android:paddingTop="@dimen/m3t_spacing_xxl"
            android:paddingEnd="@dimen/m3t_spacing_xxl"
            android:paddingBottom="@dimen/m3t_spacing_xxl">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.M3t.Card.Subtle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/m3t_drawer_section_bg">

                <TextView
                    android:id="@+id/tvAgreementContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="@dimen/m3t_spacing_xs"
                    android:padding="@dimen/m3t_spacing_xl"
                    android:text="@string/user_agreement_content"
                    android:textAppearance="@style/TextAppearance.M3t.Body.Medium"
                    android:textColor="@color/blue_glass_text" />
            </com.google.android.material.card.MaterialCardView>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.loadingindicator.LoadingIndicator
            android:id="@+id/agreementProgress"
            style="@style/Widget.M3t.LoadingIndicator.Onboarding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" />

        <LinearLayout
            android:id="@+id/agreementActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/m3t_drawer_background"
            android:orientation="vertical"
            android:paddingStart="@dimen/m3t_spacing_xxl"
            android:paddingTop="@dimen/m3t_spacing_lg"
            android:paddingEnd="@dimen/m3t_spacing_xxl"
            android:paddingBottom="@dimen/m3t_spacing_xl">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAgreementAgree"
                style="@style/Widget.M3t.Button.Filled"
                android:layout_width="match_parent"
                android:layout_height="@dimen/m3t_button_height"
                android:text="@string/user_agreement_action_next"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
