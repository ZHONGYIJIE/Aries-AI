<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/permissionSheetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/m3t_drawer_background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/permissionSheetHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/m3t_spacing_xxl"
        android:paddingTop="@dimen/m3t_spacing_md"
        android:paddingEnd="@dimen/m3t_spacing_xxl">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarPerm"
            style="@style/Widget.M3t.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/m3t_toolbar_height"
            android:layout_marginTop="@dimen/m3t_spacing_md"
            android:background="@android:color/transparent"
            app:title="@string/perm_sheet_title"
            app:titleCentered="true" />

        <TextView
            android:id="@+id/tvPermDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/m3t_spacing_sm"
            android:text="@string/perm_sheet_desc"
            android:textAppearance="@style/TextAppearance.M3t.Body.Medium"
            android:textColor="@color/blue_glass_text_dim" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/m3t_spacing_xxl"
            android:paddingTop="@dimen/m3t_spacing_xxl"
            android:paddingEnd="@dimen/m3t_spacing_xxl"
            android:paddingBottom="@dimen/m3t_spacing_xxl">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.M3t.Card.Subtle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/m3t_drawer_section_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/m3t_spacing_xl">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/perm_sheet_shizuku_title"
                        android:textAppearance="@style/TextAppearance.M3t.Title.Medium"
                        android:textColor="@color/blue_glass_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/m3t_spacing_xs"
                        android:text="@string/perm_sheet_shizuku_desc"
                        android:textAppearance="@style/TextAppearance.M3t.Body.Medium"
                        android:textColor="@color/blue_glass_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/m3t_spacing_xl"
                android:text="@string/perm_sheet_section_title"
                android:textAppearance="@style/TextAppearance.M3t.Label.Small" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.M3t.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/m3t_spacing_sm"
                app:cardBackgroundColor="@color/m3t_drawer_background"
                app:strokeWidth="@dimen/m3t_size_zero">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="@dimen/m3t_about_item_height"
                        android:orientation="horizontal"
                        android:padding="@dimen/m3t_spacing_xl">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.M3t.Card.Subtle"
                            android:layout_width="@dimen/m3t_compact_button_height"
                            android:layout_height="@dimen/m3t_compact_button_height"
                            app:cardBackgroundColor="@color/m3t_drawer_section_bg">

                            <ImageView
                                android:layout_width="@dimen/m3t_perm_sheet_icon_size"
                                android:layout_height="@dimen/m3t_perm_sheet_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_key_24"
                                app:tint="@color/blue_glass_primary" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/m3t_spacing_lg"
                            android:layout_marginEnd="@dimen/m3t_spacing_md"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/perm_sheet_accessibility_title"
                                android:textAppearance="@style/TextAppearance.M3t.Title.Medium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/m3t_spacing_xs"
                                android:text="@string/perm_sheet_accessibility_desc"
                                android:textAppearance="@style/TextAppearance.M3t.Body.Small" />

                            <TextView
                                android:id="@+id/tvPermAccStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/m3t_spacing_xs"
                                android:text="@string/perm_sheet_status_pending"
                                android:textAppearance="@style/TextAppearance.M3t.Label.Small" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPermAcc"
                            style="@style/Widget.M3t.Button.Tonal.Compact"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/m3t_compact_button_height"
                            android:text="@string/perm_sheet_action_enable"
                            android:textAllCaps="false" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/m3t_stroke_thin"
                        android:background="@color/m3t_perm_sheet_separator" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="@dimen/m3t_about_item_height"
                        android:orientation="horizontal"
                        android:padding="@dimen/m3t_spacing_xl">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.M3t.Card.Subtle"
                            android:layout_width="@dimen/m3t_compact_button_height"
                            android:layout_height="@dimen/m3t_compact_button_height"
                            app:cardBackgroundColor="@color/m3t_drawer_section_bg">

                            <ImageView
                                android:layout_width="@dimen/m3t_perm_sheet_icon_size"
                                android:layout_height="@dimen/m3t_perm_sheet_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_floating_window_24"
                                app:tint="@color/blue_glass_primary" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/m3t_spacing_lg"
                            android:layout_marginEnd="@dimen/m3t_spacing_md"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/perm_sheet_overlay_title"
                                android:textAppearance="@style/TextAppearance.M3t.Title.Medium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/m3t_spacing_xs"
                                android:text="@string/perm_sheet_overlay_desc"
                                android:textAppearance="@style/TextAppearance.M3t.Body.Small" />

                            <TextView
                                android:id="@+id/tvPermOverlayStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/m3t_spacing_xs"
                                android:text="@string/perm_sheet_status_pending"
                                android:textAppearance="@style/TextAppearance.M3t.Label.Small" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPermOverlay"
                            style="@style/Widget.M3t.Button.Tonal.Compact"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/m3t_compact_button_height"
                            android:text="@string/perm_sheet_action_settings"
                            android:textAllCaps="false" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/m3t_stroke_thin"
                        android:background="@color/m3t_perm_sheet_separator" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="@dimen/m3t_about_item_height"
                        android:orientation="horizontal"
                        android:padding="@dimen/m3t_spacing_xl">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.M3t.Card.Subtle"
                            android:layout_width="@dimen/m3t_compact_button_height"
                            android:layout_height="@dimen/m3t_compact_button_height"
                            app:cardBackgroundColor="@color/m3t_drawer_section_bg">

                            <ImageView
                                android:layout_width="@dimen/m3t_perm_sheet_icon_size"
                                android:layout_height="@dimen/m3t_perm_sheet_icon_size"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_mic_24"
                                app:tint="@color/blue_glass_primary" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/m3t_spacing_lg"
                            android:layout_marginEnd="@dimen/m3t_spacing_md"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/perm_sheet_microphone_title"
                                android:textAppearance="@style/TextAppearance.M3t.Title.Medium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/m3t_spacing_xs"
                                android:text="@string/perm_sheet_microphone_desc"
                                android:textAppearance="@style/TextAppearance.M3t.Body.Small" />

                            <TextView
                                android:id="@+id/tvPermMicStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/m3t_spacing_xs"
                                android:text="@string/perm_sheet_status_pending"
                                android:textAppearance="@style/TextAppearance.M3t.Label.Small" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPermMic"
                            style="@style/Widget.M3t.Button.Tonal.Compact"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/m3t_compact_button_height"
                            android:text="@string/perm_sheet_action_grant"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.loadingindicator.LoadingIndicator
        android:id="@+id/permissionProgress"
        style="@style/Widget.M3t.LoadingIndicator.Onboarding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" />

    <LinearLayout
        android:id="@+id/permissionSheetActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/m3t_drawer_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/m3t_spacing_xxl"
        android:paddingTop="@dimen/m3t_spacing_lg"
        android:paddingEnd="@dimen/m3t_spacing_xxl"
        android:paddingBottom="@dimen/m3t_spacing_xl">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPermGuide"
            style="@style/Widget.M3t.Button.Filled"
            android:layout_width="0dp"
            android:layout_height="@dimen/m3t_button_height"
            android:layout_weight="1"
            android:text="@string/perm_sheet_primary_action"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPermDone"
            style="@style/Widget.M3t.Button.Tonal"
            android:layout_width="0dp"
            android:layout_height="@dimen/m3t_button_height"
            android:layout_marginStart="@dimen/m3t_spacing_md"
            android:layout_weight="1"
            android:text="@string/perm_sheet_secondary_action"
            android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
