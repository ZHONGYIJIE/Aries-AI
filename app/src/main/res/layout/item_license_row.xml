<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/m3t_spacing_sm"
    android:paddingBottom="@dimen/m3t_spacing_sm">

    <TextView
        android:id="@+id/tvLibName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Library Name"
        android:textAppearance="@style/TextAppearance.M3t.Title.Medium" />

    <TextView
        android:id="@+id/tvLibDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/m3t_spacing_xxxs"
        android:text="Library description"
        android:textAppearance="@style/TextAppearance.M3t.Body.Small" />

    <TextView
        android:id="@+id/tvLibLicense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/m3t_spacing_xxxs"
        android:text="许可: Apache-2.0"
        android:textAppearance="@style/TextAppearance.M3t.Body.Small" />

</LinearLayout>
