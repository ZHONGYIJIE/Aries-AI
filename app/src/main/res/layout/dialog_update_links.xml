<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/dialogCard"
        style="@style/Widget.M3t.DialogCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="@dimen/m3t_dialog_card_margin_h"
        app:cardBackgroundColor="@color/m3t_dialog_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/m3t_dialog_padding">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/m3t_history_icon_padding">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="@string/m3t_updates_found"
                    android:textAppearance="@style/TextAppearance.M3t.Title.Large" />

                <ImageView
                    android:id="@+id/btnClose"
                    style="@style/Widget.M3t.History.CloseButton"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/m3t_history_icon_padding"
                android:text=""
                android:textAppearance="@style/TextAppearance.M3t.Body.Small" />

            <ScrollView
                android:id="@+id/scrollBody"
                android:layout_width="match_parent"
                android:layout_height="@dimen/m3t_update_links_body_height"
                android:layout_marginBottom="@dimen/m3t_spacing_md"
                android:fillViewport="true"
                android:overScrollMode="never">

                <TextView
                    android:id="@+id/tvBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textAppearance="@style/TextAppearance.M3t.Body.Medium" />
            </ScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLinks"
                android:layout_width="match_parent"
                android:layout_height="@dimen/m3t_update_links_list_height"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <LinearLayout
                android:id="@+id/actionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/m3t_spacing_lg"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenRelease"
                    style="@style/Widget.M3t.Button.Filled"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/m3t_button_height"
                    android:layout_weight="1"
                    android:text="@string/m3t_updates_view_release"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistory"
                    style="@style/Widget.M3t.Button.Tonal.Dialog"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/m3t_button_height"
                    android:layout_marginStart="@dimen/m3t_spacing_sm"
                    android:layout_weight="1"
                    android:text="@string/m3t_updates_history"
                    android:textAllCaps="false" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
