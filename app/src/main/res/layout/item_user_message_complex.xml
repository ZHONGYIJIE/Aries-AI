<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="0dp"
    android:layout_marginBottom="0dp"
    android:background="@drawable/bg_user_bubble_water"
    android:orientation="vertical">

    <TextView
        android:id="@+id/user_author_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="我"
        android:textColor="@color/m3t_on_surface_variant"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/message_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="4dp"
        android:textAppearance="@style/TextAppearance.M3t.Chat.Message"
        android:textIsSelectable="true" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/user_attachment_icons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/m3t_spacing_xs"
        android:visibility="gone" />

</LinearLayout>
