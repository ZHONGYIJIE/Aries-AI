<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/m3t_dialog_surface"
    android:orientation="vertical"
    android:padding="@dimen/m3t_dialog_padding">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/about_changelog"
        android:textAppearance="@style/TextAppearance.M3t.Title.Large" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/m3t_spacing_md"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="v1.0.0"
            android:textAppearance="@style/TextAppearance.M3t.Body.Medium" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-01-03"
            android:textAppearance="@style/TextAppearance.M3t.Body.Small" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/m3t_stroke_thin"
        android:layout_marginTop="@dimen/m3t_spacing_md"
        android:background="@color/m3t_outline_variant" />

    <TextView
        android:id="@+id/tvBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/m3t_spacing_md"
        android:textAppearance="@style/TextAppearance.M3t.Body.Medium" />

</LinearLayout>
