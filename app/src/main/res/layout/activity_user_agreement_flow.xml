<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/onboardingHost"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/m3t_drawer_background">

    <include
        android:id="@+id/pageWelcome"
        layout="@layout/page_onboarding_welcome" />

    <include
        android:id="@+id/pageAgreement"
        layout="@layout/dialog_user_agreement"
        android:visibility="gone" />

    <include
        android:id="@+id/pagePermission"
        layout="@layout/sheet_permissions"
        android:visibility="gone" />
</FrameLayout>