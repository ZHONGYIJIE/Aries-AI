<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="@color/m3t_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/m3t_outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/floatingTitleBar"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@drawable/floating_title_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp">

            <ImageButton
                android:id="@+id/btnFullscreen"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="展开全屏"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_fullscreen_24" />

            <ImageButton
                android:id="@+id/btnMinimize"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="收起"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_minimize_24"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="返回主页"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_home_24" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="关闭"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_close_24" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/m3t_outline_variant" />

        <ScrollView
            android:id="@+id/scrollArea"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/messagesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/m3t_spacing_md" />

        </ScrollView>

        <LinearLayout
            android:id="@+id/inputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/m3t_surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/m3t_spacing_md"
            android:paddingVertical="6dp">

            <EditText
                android:id="@+id/inputMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/floating_input_bg"
                android:hint="输入消息..."
                android:inputType="textMultiLine"
                android:maxHeight="80dp"
                android:maxLines="3"
                android:minHeight="34dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="@color/m3t_on_surface"
                android:textColorHint="@color/m3t_on_surface_variant"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btnAdd"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="添加"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_add_24"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="发送"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_send_24" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>

